    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maan-patel/advanced-calculator.git"
  },
  "keywords": [
    "calculator",
    "scientific-calculator",
